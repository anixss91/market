generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Float
  image       String
  images      String[]  @default([])
  category    String?
  description String
  stock       Int
  createdAt   DateTime @default(now())
  orders      Order[]
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("user")
  createdAt    DateTime  @default(now())
  addresses    Address[]
  orders       Order[]
}

model Address {
  id        Int      @id @default(autoincrement())
  label     String?
  wilaya    String
  city      String
  details   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
}

model Order {
  id             Int      @id @default(autoincrement())
  fullName       String
  phone          String
  wilaya         String
  city           String
  deliveryMethod String
  status         String   @default("pending")
  quantity       Int      @default(1)
  createdAt      DateTime @default(now())
  user           User?    @relation(fields: [userId], references: [id])
  userId         Int?
  product        Product  @relation(fields: [productId], references: [id])
  productId      Int
}